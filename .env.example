# Copy to `.env` in the repo root and set every required value. Never commit `.env`.
# Quick start: see docs/how-to-run.md — then open http://localhost:8080 (or HTTP_PORT below).

ENVIRONMENT=development

# --- Required for Docker Compose ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5432

# JWT signing (auth + services that validate Bearer tokens). Use a long random secret, e.g. openssl rand -hex 32
JWT_SECRET=

# --- Auth: password reset & email ---
# When true, forgot-password may return dev_reset_token when SMTP is unset (turn OFF in production).
PASSWORD_RESET_RETURN_TOKEN=true
# Base URL for links in emails; match how users reach the app (Compose + NGINX default below).
FRONTEND_PUBLIC_URL=http://localhost:8080
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# --- Host-only / tooling (optional) ---
# Async URL for Python on the host pointing at Compose Postgres (must match POSTGRES_* above).
DATABASE_URL=
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Published ports: host → container :8000 (Python) or :3000 / :80 (edge)
GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
INGESTION_SERVICE_PORT=8002
RETRIEVAL_SERVICE_PORT=8003
LLM_SERVICE_PORT=8004
WORKER_SERVICE_PORT=8005
FRONTEND_PORT=3000
HTTP_PORT=8080

# --- Next.js local dev (frontend/.env.local) ---
# Browser calls /api/*; Next rewrites to this gateway URL. Not used by the production Docker image
# (Compose passes GATEWAY_INTERNAL_URL as a build arg: http://gateway-service:8000).
GATEWAY_INTERNAL_URL=http://127.0.0.1:8000

# Optional: scripts or IDE hitting services directly on the host
AUTH_SERVICE_URL=http://127.0.0.1:8001
INGESTION_SERVICE_URL=http://127.0.0.1:8002
RETRIEVAL_SERVICE_URL=http://127.0.0.1:8003
LLM_SERVICE_URL=http://127.0.0.1:8004

# --- OpenAI (worker embeddings, retrieval query embed, LLM RAG) ---
# Without a key, uploads queue but indexing and query-time AI steps will not succeed.
OPENAI_API_KEY=

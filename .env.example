# Runtime
ENVIRONMENT=development

# PostgreSQL (pgvector image)
POSTGRES_USER=knowledgemesh
POSTGRES_PASSWORD=knowledgemesh
POSTGRES_DB=knowledgemesh
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://knowledgemesh:knowledgemesh@localhost:5432/knowledgemesh

# Redis (cache + job transport)
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Service ports (host → container 8000 for Python services)
GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
INGESTION_SERVICE_PORT=8002
RETRIEVAL_SERVICE_PORT=8003
LLM_SERVICE_PORT=8004
WORKER_SERVICE_PORT=8005

# Frontend + edge
FRONTEND_PORT=3000
HTTP_PORT=8080

# LLM (used in later milestones)
OPENAI_API_KEY=

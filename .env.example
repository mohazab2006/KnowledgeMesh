# Copy to `.env` and fill every **required** value. Never commit `.env`.
# GitGuardian and similar tools flag example passwords in tracked files — keep real secrets only in `.env`.

ENVIRONMENT=development

# --- Required for Docker Compose (postgres + auth-service) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5432

# JWT signing key for auth-service (use a long random string, e.g. openssl rand -hex 32)
JWT_SECRET=

# Password reset (auth-service)
# When true, POST /v1/auth/forgot-password may return dev_reset_token if the user exists (no SMTP). Turn OFF in production.
PASSWORD_RESET_RETURN_TOKEN=true
# Used in reset links inside emails; match how you open the app (e.g. http://localhost:8080 with NGINX, or :3000 for Next only).
FRONTEND_PUBLIC_URL=http://localhost:8080
# Optional SMTP (leave SMTP_HOST empty to skip email; use dev token or configure SMTP for real mail).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# --- Local development (auth-service / tools on the host) ---
# Use 127.0.0.1 as host. Must match POSTGRES_* above.
DATABASE_URL=

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Service ports (host → container 8000 for Python services)
GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
INGESTION_SERVICE_PORT=8002
RETRIEVAL_SERVICE_PORT=8003
LLM_SERVICE_PORT=8004
WORKER_SERVICE_PORT=8005

# Frontend + edge
FRONTEND_PORT=3000
HTTP_PORT=8080
# Used by `next dev` when you add the same key to frontend/.env.local (see frontend/.env.example).
# The Docker frontend image sets GATEWAY_INTERNAL_URL at image build time to http://gateway-service:8000.
GATEWAY_INTERNAL_URL=http://127.0.0.1:8000

AUTH_SERVICE_URL=http://127.0.0.1:8001
INGESTION_SERVICE_URL=http://127.0.0.1:8002
RETRIEVAL_SERVICE_URL=http://127.0.0.1:8003
LLM_SERVICE_URL=http://127.0.0.1:8004

# --- OpenAI (worker embeddings + retrieval query embed + LLM RAG) ---
# Create at https://platform.openai.com/api-keys — never commit real keys.
# Required for worker-service to move documents from `queued` → `indexed` (embeddings).
OPENAI_API_KEY=
